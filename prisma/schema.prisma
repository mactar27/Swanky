generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  description String?  @db.Text
  price       Float
  gsm         Int?
  imageUrl    String?  @db.LongText
  category    String
  stock       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orderItems  OrderItem[]
  tieredPrices TieredPrice[]
}

model TieredPrice {
  id        Int     @id @default(autoincrement())
  productId Int
  minQty    Int
  price     Float
  product   Product @relation(fields: [productId], references: [id])
}

model Order {
  id          Int      @id @default(autoincrement())
  orderNumber String   @unique
  clientName  String
  clientEmail String
  status      String   @default("EN_ATTENTE") // EN_ATTENTE, EN_PRODUCTION, IMPRIME, EXPEDIE
  total       Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  items       OrderItem[]
}

model OrderItem {
  id        Int      @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Int
  price     Float
  order     Order    @relation(fields: [orderId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
}

model QuoteRequest {
  id              Int      @id @default(autoincrement())
  clientName      String
  clientEmail     String
  clientPhone     String?
  productType     String
  technique       String
  shippingAddress String?  @db.Text
  logoUrl         String?  @db.LongText
  status          String   @default("NOUVEAU") // NOUVEAU, TRAITE
  createdAt       DateTime @default(now())
}
